{
  "globs": ["*.md", ".github/**/*.md", "docs/**/*.md", "tutorials/**/*.md"],
  "config": {
    "MD013": false,
    "MD024": {
      "siblings_only": true,
    },
    "MD033": {
      "allowed_elements": ["div", "link", "span", "table", "td", "tr"],
    },
    "MD041": {
      "allow_preamble": true,
    },
  },
}
